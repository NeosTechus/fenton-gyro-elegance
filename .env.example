# ── Firebase Auth & Firestore ─────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ── Valor: Online ordering (ePage) — Vercel serverless env vars ──────────
# These are set in Vercel Dashboard > Settings > Environment Variables
# (NOT prefixed with VITE_ — they are server-side only)
# VALOR_APPID=your-app-id
# VALOR_APPKEY=your-app-key
# VALOR_EPI=your-vt-epi
# VALOR_API_URL=https://securelinktest.valorpaytech.com:4430/

# ── Valor: Override checkout API URL (optional) ──────────────────────────
# Defaults to /api/create-valor-checkout on Vercel. Only set this if
# hosting the API route somewhere else.
# VITE_VALOR_CHECKOUT_URL=

# ── Valor: POS terminal (in-store WebSocket) ─────────────────────────────
VITE_VALOR_WS_URL=
VITE_VALOR_EPI=2501439074
